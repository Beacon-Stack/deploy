# ============================================================================
# Beacon Stack — dev configuration
# Copy to .env to run the deploy stack against locally-built images with
# developer-friendly volume paths:
#
#   cp .env.dev.example .env
#   ./setup-secrets.sh
#   docker compose up -d
#
# The COMPOSE_FILE line below is what auto-applies docker-compose.dev.yml.
# ============================================================================

# --- General ----------------------------------------------------------------

TZ=UTC

# Apply the dev override on every `docker compose ...` invocation.
COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# vpn + flaresolverr by default — the old dev stack had FlareSolverr on
# all the time. Swap 'vpn' for 'novpn' to skip the tunnel.
COMPOSE_PROFILES=vpn,flaresolverr

# --- Ports ------------------------------------------------------------------

# Postgres is not published by default. Uncomment the 'ports:' block in
# docker-compose.yml to expose it.
# POSTGRES_PORT=5432

PULSE_PORT=9696
PULSE_LOG_LEVEL=info

PILOT_PORT=8383
PILOT_LOG_LEVEL=info

PRISM_PORT=8282
PRISM_LOG_LEVEL=info

HAUL_PORT=8484
HAUL_PEER_PORT=6881
HAUL_LOG_LEVEL=info

FLARESOLVERR_PORT=8191
FLARESOLVERR_LOG_LEVEL=info

# --- Config paths (dev: point at ~/.config so UI settings survive rebuilds) -

PULSE_CONFIG_PATH=${HOME}/.config/pulse
PILOT_CONFIG_PATH=${HOME}/.config/pilot
PRISM_CONFIG_PATH=${HOME}/.config/prism
HAUL_CONFIG_PATH=/opt/media/haul/config
GLUETUN_CONFIG_PATH=${HOME}/.config/gluetun

# --- Media paths (dev: the existing /opt/media layout) ----------------------

DOWNLOADS_PATH=/opt/media/downloads
TV_PATH=/opt/media/pilot/shows
MOVIES_PATH=/opt/media/prism/movies

# --- VPN (Gluetun) ----------------------------------------------------------
# The old dev stack used PIA via a wireguard-specific container. Gluetun
# supports PIA too — over OpenVPN by default. See the Gluetun wiki for
# region codes: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers/private-internet-access

VPN_SERVICE_PROVIDER=private internet access
VPN_TYPE=openvpn
VPN_SERVER_REGIONS=CA Toronto
VPN_PORT_FORWARDING=on
VPN_PORT_FORWARDING_PROVIDER=

# WireGuard settings (only if VPN_TYPE=wireguard)
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=

# Note on PIA dynamic port forwarding:
# Gluetun writes the PIA-assigned port to /tmp/gluetun/forwarded_port, but
# Haul currently binds HAUL_PEER_PORT at startup and doesn't pick up
# subsequent rotations. Outgoing peers, DHT, and trackers all work; only
# incoming peer dials require the PIA-assigned port to match HAUL_PEER_PORT.
# A port-sync sidecar is a planned follow-up.
