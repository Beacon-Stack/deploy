# ============================================================================
# Beacon Stack — developer environment
# Copy to .env for running the deploy stack against locally-built images.
#
#   cp .env.dev.example .env
#   docker compose up -d --build
#
# Local bind mounts (paths for /config, /tv, /movies, /downloads) go in
# docker-compose.override.yml — not here. See docker-compose.override.example.yml
# for a starting point.
# ============================================================================

# Auto-load the dev overlay (builds from local sources in sibling repos).
# Append :docker-compose.vpn.yml to also tunnel Haul through Gluetun.
COMPOSE_FILE=docker-compose.yml:docker-compose.override.yml:docker-compose.dev.yml

# Start FlareSolverr alongside the main stack.
COMPOSE_PROFILES=flaresolverr

# --- Third-party metadata keys (baked in at build time) --------------------
# Pilot and Prism bake TMDB/Trakt keys into the binary via ldflags. CI
# pulls these from org secrets for published images, so `docker compose
# pull` users already have them. For local builds, set them here —
# otherwise the built image ships with empty defaults and metadata
# lookups will 503 until you set a runtime override in the Settings UI.
# PILOT_TMDB_API_KEY=
# PILOT_TRAKT_CLIENT_ID=
# PRISM_TMDB_API_KEY=
# PRISM_TRAKT_CLIENT_ID=

# --- VPN (only if docker-compose.vpn.yml is loaded) ------------------------
# VPN_USERNAME=
# VPN_PASSWORD=

# Note on PIA dynamic port forwarding: Gluetun writes the PIA-assigned
# port to /tmp/gluetun/forwarded_port, but Haul binds HAUL_TORRENT_LISTEN_PORT
# at startup and doesn't pick up subsequent rotations. Outgoing peers,
# DHT, and trackers all work; only incoming peer dials require the port
# to match 6881.
