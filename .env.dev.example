# ============================================================================
# Beacon Stack — dev configuration
# Copy to .env to run the deploy stack against locally-built images with
# developer-friendly volume paths:
#
#   cp .env.dev.example .env
#   docker compose up -d --build
#
# The COMPOSE_FILE line below is what auto-applies docker-compose.dev.yml.
# Add docker-compose.vpn.yml to that list (and set VPN_USERNAME /
# VPN_PASSWORD below) to enable the Gluetun tunnel.
# ============================================================================

# --- General ----------------------------------------------------------------

TZ=UTC

# Apply the dev override on every `docker compose ...` invocation.
# For VPN: COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml:docker-compose.vpn.yml
COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# Start FlareSolverr by default — the old dev stack had it always on.
COMPOSE_PROFILES=flaresolverr

# --- Ports ------------------------------------------------------------------

# Postgres is not published by default. Uncomment the 'ports:' block in
# docker-compose.yml to expose it.
# POSTGRES_PORT=5432

PULSE_PORT=9696
PULSE_LOG_LEVEL=info

PILOT_PORT=8383
PILOT_LOG_LEVEL=info

PRISM_PORT=8282
PRISM_LOG_LEVEL=info

HAUL_PORT=8484
HAUL_PEER_PORT=6881
HAUL_LOG_LEVEL=info

FLARESOLVERR_PORT=8191
FLARESOLVERR_LOG_LEVEL=info

# --- Config paths (dev: all under ~/.config/beacon/ so app settings survive
#                       image rebuilds and don't scatter across ~/.config/) -

PULSE_CONFIG_PATH=${HOME}/.config/beacon/pulse
PILOT_CONFIG_PATH=${HOME}/.config/beacon/pilot
PRISM_CONFIG_PATH=${HOME}/.config/beacon/prism
HAUL_CONFIG_PATH=${HOME}/.config/beacon/haul
GLUETUN_CONFIG_PATH=${HOME}/.config/beacon/gluetun

# --- Media paths (dev: the existing /opt/media layout) ----------------------

DOWNLOADS_PATH=/opt/media/downloads
TV_PATH=/opt/media/pilot/shows
MOVIES_PATH=/opt/media/prism/movies

# --- VPN (only needed if docker-compose.vpn.yml is in COMPOSE_FILE) --------
# Gluetun refuses to start without these two. Uncomment and fill in when
# you switch COMPOSE_FILE on above to include docker-compose.vpn.yml.
# VPN_USERNAME=
# VPN_PASSWORD=

VPN_SERVICE_PROVIDER=private internet access
VPN_TYPE=openvpn
VPN_SERVER_REGIONS=CA Toronto
VPN_PORT_FORWARDING=on
VPN_PORT_FORWARDING_PROVIDER=

# WireGuard settings (only if VPN_TYPE=wireguard)
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=

# --- Third-party metadata keys (pilot + prism bake these in at build time) -
# CI sets these from repo secrets when building the published images, so
# pulled images work out of the box. Local builds via docker-compose.dev.yml
# need you to provide them — otherwise the binary ships with empty
# defaults and series/movie lookups 503. Set them here OR use the runtime
# overrides PILOT_TVDB_API_KEY / PRISM_TMDB_API_KEY / PILOT_TRAKT_CLIENT_ID
# in .env if you'd rather avoid rebuilding.
# PILOT_TMDB_API_KEY=
# PILOT_TRAKT_CLIENT_ID=
# PRISM_TMDB_API_KEY=
# PRISM_TRAKT_CLIENT_ID=

# Note on PIA dynamic port forwarding:
# Gluetun writes the PIA-assigned port to /tmp/gluetun/forwarded_port, but
# Haul currently binds HAUL_PEER_PORT at startup and doesn't pick up
# subsequent rotations. Outgoing peers, DHT, and trackers all work; only
# incoming peer dials require the PIA-assigned port to match HAUL_PEER_PORT.
# A port-sync sidecar is a planned follow-up.
