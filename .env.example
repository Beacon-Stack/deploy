# ============================================================================
# Beacon Stack Configuration
# Copy this file to .env and edit the values below.
# Lines starting with # are comments.
# ============================================================================

# --- General ----------------------------------------------------------------

# Timezone for all containers (IANA format)
TZ=UTC

# Which stack variant to run. Compose profiles select a set of services:
#   vpn                  → default. Haul routed through Gluetun.
#   novpn                → Haul exposed directly on the host (no VPN).
#   vpn,flaresolverr     → add the FlareSolverr proxy.
COMPOSE_PROFILES=vpn

# --- Postgres ---------------------------------------------------------------
# The superuser password is in secrets/pg-password.txt (not here).
# Postgres is not published to the host by default — apps reach it over the
# internal 'beacon-net' bridge. Uncomment the 'ports:' block in
# docker-compose.yml under the postgres service to expose it on the host.
# POSTGRES_PORT=5432

# --- Pulse (control plane) --------------------------------------------------
# Web UI: http://localhost:${PULSE_PORT}
PULSE_PORT=9696
PULSE_LOG_LEVEL=info
PULSE_CONFIG_PATH=./config/pulse

# FlareSolverr URL — only set this if you're running FlareSolverr
# (docker compose --profile flaresolverr up -d)
# PULSE_FLARESOLVERR_URL=http://flaresolverr:8191

# --- Pilot (TV series manager) ----------------------------------------------
# Web UI: http://localhost:${PILOT_PORT}
PILOT_PORT=8383
PILOT_LOG_LEVEL=info
PILOT_CONFIG_PATH=./config/pilot

# --- Prism (movie collection manager) ---------------------------------------
# Web UI: http://localhost:${PRISM_PORT}
PRISM_PORT=8282
PRISM_LOG_LEVEL=info
PRISM_CONFIG_PATH=./config/prism

# --- Haul (BitTorrent client) ------------------------------------------------
# Web UI: http://localhost:${HAUL_PORT} (served through the VPN container)
HAUL_PORT=8484
HAUL_PEER_PORT=6881
HAUL_LOG_LEVEL=info
HAUL_CONFIG_PATH=./config/haul

# --- Media paths -------------------------------------------------------------
# Where completed downloads go (shared between Haul, Pilot, and Prism)
DOWNLOADS_PATH=./data/downloads

# Where Pilot stores TV shows
TV_PATH=./data/tv

# Where Prism stores movies
MOVIES_PATH=./data/movies

# --- VPN (Gluetun) -----------------------------------------------------------
# Provider name — see https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
# Examples: "private internet access", "mullvad", "nordvpn", "surfshark", "protonvpn"
VPN_SERVICE_PROVIDER=private internet access

# Protocol: "openvpn" or "wireguard"
VPN_TYPE=openvpn

# Server region(s) — provider-specific, comma-separated for multiple
VPN_SERVER_REGIONS=Netherlands

# Port forwarding (PIA and ProtonVPN support this — improves torrent speeds)
VPN_PORT_FORWARDING=on
# Leave blank unless your provider requires a specific value
VPN_PORT_FORWARDING_PROVIDER=

# WireGuard settings (only if VPN_TYPE=wireguard)
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=

# Gluetun data directory
GLUETUN_CONFIG_PATH=./config/gluetun

# --- FlareSolverr (optional, add 'flaresolverr' to COMPOSE_PROFILES) ---------
FLARESOLVERR_PORT=8191
FLARESOLVERR_LOG_LEVEL=info
