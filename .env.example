# ============================================================================
# Beacon Stack Configuration
# Copy this file to .env ONLY if you need to override a default below.
# The stack runs fine with no .env file at all — all values here are
# already the compose defaults.
# ============================================================================

# --- General ----------------------------------------------------------------

# Timezone for all containers (IANA format)
TZ=UTC

# --- Postgres ---------------------------------------------------------------
# Postgres is not published to the host by default — apps reach it over the
# internal 'beacon-net' bridge. Uncomment the 'ports:' block in
# docker-compose.yml under the postgres service to expose it on the host.
# POSTGRES_PORT=5432

# --- Pulse (control plane) --------------------------------------------------
PULSE_PORT=9696
PULSE_LOG_LEVEL=info
PULSE_CONFIG_PATH=./config/pulse

# FlareSolverr URL — only set this if you're running FlareSolverr
# (COMPOSE_PROFILES=flaresolverr docker compose up -d)
# PULSE_FLARESOLVERR_URL=http://flaresolverr:8191

# --- Pilot (TV series manager) ----------------------------------------------
PILOT_PORT=8383
PILOT_LOG_LEVEL=info
PILOT_CONFIG_PATH=./config/pilot

# --- Prism (movie collection manager) ---------------------------------------
PRISM_PORT=8282
PRISM_LOG_LEVEL=info
PRISM_CONFIG_PATH=./config/prism

# --- Haul (BitTorrent client) -----------------------------------------------
HAUL_PORT=8484
HAUL_PEER_PORT=6881
HAUL_LOG_LEVEL=info
HAUL_CONFIG_PATH=./config/haul

# --- Media paths ------------------------------------------------------------
DOWNLOADS_PATH=./data/downloads
TV_PATH=./data/tv
MOVIES_PATH=./data/movies

# --- FlareSolverr (optional, add 'flaresolverr' to COMPOSE_PROFILES) --------
FLARESOLVERR_PORT=8191
FLARESOLVERR_LOG_LEVEL=info

# ============================================================================
# VPN — only needed when using docker-compose.vpn.yml override
#
# To enable the VPN:
#   1. Set VPN_USERNAME and VPN_PASSWORD below (required — compose will
#      refuse to start the vpn service if they're unset).
#   2. Optionally tune VPN_SERVICE_PROVIDER / VPN_SERVER_REGIONS for your
#      provider (see https://github.com/qdm12/gluetun-wiki).
#   3. Run:
#        docker compose -f docker-compose.yml -f docker-compose.vpn.yml up -d
#      or set COMPOSE_FILE below so plain `docker compose` picks it up.
# ============================================================================

# COMPOSE_FILE=docker-compose.yml:docker-compose.vpn.yml

# VPN_USERNAME=
# VPN_PASSWORD=

VPN_SERVICE_PROVIDER=private internet access
VPN_TYPE=openvpn
VPN_SERVER_REGIONS=Netherlands
VPN_PORT_FORWARDING=on
VPN_PORT_FORWARDING_PROVIDER=

# WireGuard settings (only if VPN_TYPE=wireguard)
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=

GLUETUN_CONFIG_PATH=./config/gluetun
