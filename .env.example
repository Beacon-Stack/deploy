# ============================================================================
# Beacon Stack — environment file
#
# Copy this file to .env and edit the values you care about. Everything is
# optional EXCEPT the media paths in the "Media library" section — those
# need to point at real directories on your host.
#
#   cp .env.example .env
#   # edit .env
#   docker compose up -d
# ============================================================================

# --- Media library (REQUIRED) -----------------------------------------------
# Where your media lives on the host. These three paths MUST be on the same
# filesystem — Beacon uses hardlinks + atomic moves for imports, and falls
# back to slow file copies when paths span filesystems.
#
# Easiest layout: everything under one root.
#   TV_PATH=/opt/media/tv
#   MOVIES_PATH=/opt/media/movies
#   DOWNLOADS_PATH=/opt/media/downloads

TV_PATH=/path/to/tv
MOVIES_PATH=/path/to/movies
DOWNLOADS_PATH=/path/to/downloads

# --- Timezone ---------------------------------------------------------------
# IANA timezone, e.g. America/New_York, Europe/London, Asia/Tokyo. Used by
# all services for log timestamps and scheduled tasks.

TZ=UTC

# --- Web UI ports -----------------------------------------------------------
# Change these if another service on your host already uses one of the
# defaults. The container-internal ports (right-hand side of the mapping in
# docker-compose.yml) don't change.

# PULSE_PORT=9696
# PILOT_PORT=8383
# PRISM_PORT=8282
# HAUL_PORT=8484
# HAUL_TORRENT_PORT=6881
# FLARESOLVERR_PORT=8191

# --- Config storage (optional) ----------------------------------------------
# Per-app config and database files. Defaults to ./config/<app> next to this
# file, which works fine for most setups. Override only if you want configs
# on a different volume (e.g., a fast SSD).

# PULSE_CONFIG_PATH=./config/pulse
# PILOT_CONFIG_PATH=./config/pilot
# PRISM_CONFIG_PATH=./config/prism
# HAUL_CONFIG_PATH=./config/haul
# GLUETUN_CONFIG_PATH=./config/gluetun

# --- Logging ----------------------------------------------------------------
# debug | info | warn | error. Default is info.

# LOG_LEVEL=info

# --- Dashboard integrations (optional) --------------------------------------
# Pulse's dashboard can surface live container resource usage and VPN status
# when given access to the Docker socket and Gluetun's control server. Both
# default off; the dashboard works fine without them — just without those
# panels.
#
# Docker socket — opt in by uncommenting BOTH PULSE_DASHBOARD_DOCKER_SOCKET
# and the /var/run/docker.sock volume mount in docker-compose.yml. Read-only
# on disk, but still effectively grants root on most Docker builds. Only
# enable if you trust the Pulse container.
#
# VPN status — auto-set by docker-compose.vpn.yml when the VPN overlay is
# loaded. Override here to point at a Gluetun running elsewhere, or set to
# "" to disable.
# PULSE_DASHBOARD_GLUETUN_URL=http://vpn:8000

# Container-name overrides for non-standard deployments belong in
# config/pulse/config.yaml — env vars don't handle map values well.
#   dashboard:
#     container_names:
#       Haul: haul-prod

# ============================================================================
# OPTIONAL OVERLAYS
# ============================================================================
# COMPOSE_FILE tells `docker compose` which files to load. Uncomment a line
# below to enable an overlay.

# Route Haul through a VPN tunnel (Gluetun). Requires VPN credentials below.
# COMPOSE_FILE=docker-compose.yml:docker-compose.vpn.yml

# Enable optional services. FlareSolverr handles Cloudflare-protected
# indexers (1337x, kickasstorrents, etc.). Without it, those indexers
# return HTTP 403 and Pilot/Prism searches miss MANY releases. Highly
# recommended.
# COMPOSE_PROFILES=flaresolverr
#
# To wire FlareSolverr into Pulse, also uncomment the matching
# PULSE_FLARESOLVERR_URL line in docker-compose.yml. Set the value
# below only if running FlareSolverr externally (different host/port):
# PULSE_FLARESOLVERR_URL=http://flaresolverr:8191

# --- VPN credentials (only when docker-compose.vpn.yml is loaded) -----------
# VPN_USERNAME=
# VPN_PASSWORD=

# --- VPN provider tuning (optional) -----------------------------------------
# Defaults work for Private Internet Access. Gluetun supports 30+ providers;
# see https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers.

# VPN_SERVICE_PROVIDER=private internet access
# VPN_TYPE=openvpn                     # or wireguard
# VPN_SERVER_REGIONS=Netherlands
# VPN_PORT_FORWARDING=on               # PIA and ProtonVPN support this

# WireGuard auth — uncomment these AND set VPN_TYPE=wireguard, then
# uncomment the matching lines in docker-compose.vpn.yml.
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=
