# ============================================================================
# Beacon Stack — environment file
#
# Only needed if you're using the VPN override. The base stack runs with
# no .env file at all.
#
# To enable the VPN tunnel:
#   1. Copy this file:    cp .env.example .env
#   2. Fill in your VPN credentials below.
#   3. Run:               docker compose up -d
# ============================================================================

# Auto-load the VPN overlay on every `docker compose` invocation.
COMPOSE_FILE=docker-compose.yml:docker-compose.vpn.yml

# VPN credentials — required when docker-compose.vpn.yml is loaded.
VPN_USERNAME=
VPN_PASSWORD=

# Optional: WireGuard instead of OpenVPN. Set VPN_TYPE=wireguard in the
# VPN overlay file and uncomment these.
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=

# Optional: run FlareSolverr for Cloudflare-protected indexers.
# COMPOSE_PROFILES=flaresolverr
