# Environment file (contains user-specific config)
.env

# Local compose override — per-maintainer bind mounts, TrueNAS paths,
# testing config. Auto-loaded by `docker compose` alongside the base file.
docker-compose.override.yml

# Runtime data created by the stack (only present when the maintainer
# override binds these into the container; end users bring their own)
data/
config/

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

